{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "docker: build",
      "type": "shell",
      "command": "docker-compose",
      "args": ["build"],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false
      }
    },
    {
      "label": "docker: up",
      "type": "shell",
      "command": "docker-compose",
      "args": ["up", "-d"],
      "group": "none",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false
      }
    },
    {
      "label": "docker: down",
      "type": "shell",
      "command": "docker-compose",
      "args": ["down"],
      "group": "none",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false
      }
    },
    {
      "label": "docker: start",
      "type": "shell",
      "command": "echo '✅ Docker services started successfully'",
      "dependsOn": ["docker: build", "docker: up"],
      "dependsOrder": "sequence",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "shared",
        "clear": false
      },
      "problemMatcher": []
    },
    {
      "label": "docker: restart",
      "type": "shell",
      "command": "echo '✅ Docker services restarted successfully'",
      "dependsOn": ["docker: down", "docker: build", "docker: up"],
      "dependsOrder": "sequence",
      "group": "none",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "shared",
        "clear": false
      },
      "problemMatcher": []
    }
  ]
}